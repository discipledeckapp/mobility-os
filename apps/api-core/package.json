{
  "name": "@mobility-os/api-core",
  "version": "0.0.0",
  "private": true,
  "description": "Tenant operations API — fleet, drivers, remittance, accounting",
  "scripts": {
    "build": "prisma generate --schema=src/database/prisma/schema.prisma && nest build",
    "dev": "nest start --watch",
    "dev:local": "PORT=3001 TENANT_WEB_URL=http://localhost:3000 nest start --watch",
    "start": "node dist/main",
    "lint": "biome check ./src",
    "type-check": "tsc --noEmit --incremental false",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "bash migrate-safe.sh",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "ts-node src/database/seed/seed.ts",
    "cli:seed-test-user": "ts-node src/cli/seed-test-user.ts",
    "cli:seed-vehicle-vin-decodes": "ts-node src/cli/seed-vehicle-vin-decodes.ts",
    "cli:import-vehicle-catalog": "ts-node src/cli/import-vehicle-catalog.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1015.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^7.0.0",
    "@mobility-os/authz-model": "workspace:*",
    "@mobility-os/domain-config": "workspace:*",
    "@mobility-os/env-config": "workspace:*",
    "@mobility-os/intelligence-domain": "workspace:*",
    "@mobility-os/tenancy-domain": "workspace:*",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-fastify": "^10.4.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^8.0.0",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.22.0",
    "@aws-sdk/client-s3": "^3.916.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.0",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0"
  },
  "prisma": {
    "schema": "src/database/prisma/schema.prisma"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.(spec|e2e-spec)\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  }
}
