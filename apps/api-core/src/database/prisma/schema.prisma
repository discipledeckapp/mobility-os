// =============================================================================
// Tenant Operations Plane — Prisma Schema (api-core)
//
// Table naming: no prefix — this is the default operational plane.
// Status fields use String, not Prisma enums, so status transitions
// never require a schema migration. Valid values are enforced by the
// service layer using @mobility-os/domain-config status registries.
//
// Cross-plane references (e.g. to intel_persons in api-intelligence) are
// plain String fields. Prisma cannot model cross-schema relations; integrity
// is maintained at the application level.
//
// Generated client output: default @prisma/client runtime package
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Tenants ───────────────────────────────────────────────────────────────────
// The root of the billing and access-control hierarchy.
// One tenant = one SaaS subscription.

model Tenant {
  id      String @id @default(cuid())
  // URL-safe identifier used in subdomains and API paths.
  slug    String @unique
  name    String
  // ISO 3166-1 alpha-2 — references domain-config country registry.
  country String
  // TenantStatus values from @mobility-os/tenancy-domain.
  status  String @default("prospect")
  // Arbitrary platform metadata (e.g. CRM notes, onboarding flags).
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessEntities BusinessEntity[]
  users            User[]

  @@map("tenants")
}

// ── Business Entities ─────────────────────────────────────────────────────────
// A legal or commercial entity operated under a tenant account.
// Enterprise tenants may have many (e.g. one per city or legal entity).

model BusinessEntity {
  id       String @id @default(cuid())
  tenantId String
  name     String
  // May differ from tenant.country for multi-country enterprise operators.
  country  String
  // References domain-config BUSINESS_MODELS slug (hire-purchase, lease, etc.).
  businessModel String
  status        String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  operatingUnits OperatingUnit[]

  @@index([tenantId])
  @@map("business_entities")
}

// ── Operating Units ───────────────────────────────────────────────────────────
// A branch, depot, or operational location within a business entity.

model OperatingUnit {
  id               String @id @default(cuid())
  // Denormalized for efficient row-level filtering without joins.
  tenantId         String
  businessEntityId String
  name             String
  status           String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessEntity BusinessEntity @relation(fields: [businessEntityId], references: [id], onDelete: Restrict)
  fleets         Fleet[]

  @@index([tenantId])
  @@index([businessEntityId])
  @@map("operating_units")
}

// ── Fleets ────────────────────────────────────────────────────────────────────
// A managed group of vehicles within an operating unit.

model Fleet {
  id              String @id @default(cuid())
  tenantId        String
  operatingUnitId String
  name            String
  // References domain-config BUSINESS_MODELS slug — may differ from the
  // parent business entity's default model (e.g. mixed hire-purchase + lease fleets).
  businessModel String
  status        String @default("active")

  // Fleet-level maintenance defaults — inherited by vehicles unless overridden per vehicle.
  maintenanceScheduleType String?
  maintenanceIntervalDays Int?
  maintenanceIntervalKm   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  operatingUnit OperatingUnit @relation(fields: [operatingUnitId], references: [id], onDelete: Restrict)
  drivers       Driver[]
  guarantors    Guarantor[]
  vehicles      Vehicle[]

  @@index([tenantId])
  @@index([operatingUnitId])
  @@map("fleets")
}

// ── Vehicle Catalog ───────────────────────────────────────────────────────────
// Global local catalog of makers and models used to bootstrap operator choices.
// Runtime UI reads from this local catalog, not the external bootstrap API.
// NHTSA vPIC is used only for import/bootstrap and VIN enrichment.

model VehicleMaker {
  id             String @id @default(cuid())
  name           String
  normalizedName String @unique
  status         String @default("active")
  externalSource String?
  externalId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  models     VehicleCatalogModel[]
  vinDecodes VehicleVinDecode[]

  @@index([status])
  @@map("vehicle_makers")
}

model VehicleCatalogModel {
  id               String @id @default(cuid())
  makerId          String
  name             String
  normalizedName   String
  status           String @default("active")
  vehicleCategory  String?
  sourceTypeLabel  String?
  externalSource   String?
  externalId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  maker      VehicleMaker        @relation(fields: [makerId], references: [id], onDelete: Restrict)
  vinDecodes VehicleVinDecode[]

  @@unique([makerId, normalizedName])
  @@index([makerId])
  @@index([status])
  @@index([vehicleCategory])
  @@map("vehicle_models")
}

// VIN decode snapshots used for audit/debugging and local catalog enrichment.
// Raw decode payloads stay here instead of bloating the operational vehicles table.

model VehicleVinDecode {
  id                 String @id @default(cuid())
  vin                String
  normalizedVin      String
  decodeKey          String @unique
  requestedModelYear Int?
  status             String @default("decoded")
  source             String @default("nhtsa-vpic")
  sourceVersion      String?
  errorCode          String?
  errorText          String?
  rawPayload         Json
  decodedMake        String?
  decodedModel       String?
  decodedModelYear   Int?
  vehicleType        String?
  bodyClass          String?
  manufacturerName   String?
  makerId            String?
  modelId            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  maker VehicleMaker?        @relation(fields: [makerId], references: [id], onDelete: SetNull)
  model VehicleCatalogModel? @relation(fields: [modelId], references: [id], onDelete: SetNull)

  @@index([normalizedVin])
  @@index([makerId])
  @@index([modelId])
  @@map("vehicle_vin_decodes")
}

// ── Drivers ───────────────────────────────────────────────────────────────────
// An individual who operates a vehicle under a tenant fleet.
// Distinct from User — drivers are operational subjects, not platform users.
//
// personId: cross-schema reference to intel_persons.id in api-intelligence.
// Set after identity resolution completes. Null until then.
// See docs/intelligence/person-graph.md.

model Driver {
  id       String @id @default(cuid())
  tenantId String
  fleetId  String
  // DriverStatus from domain-config DRIVER_STATUS_CODES:
  // active | inactive | suspended | terminated
  status   String @default("inactive")

  // Personal details — name and phone are optional at admin-creation stage;
  // the driver completes them during self-service onboarding.
  firstName   String?
  lastName    String?
  // E.164 format — optional; driver may be created with email only.
  phone       String?
  // Nullable — driver may not yet have a linked email
  email       String?
  // ISO 8601 date string (YYYY-MM-DD). Not DateTime — avoids tz ambiguity.
  dateOfBirth String?
  gender      String?
  // ISO 3166-1 alpha-2
  nationality String?
  selfieImageUrl   String?
  providerImageUrl String?
  identitySignatureImageUrl String?
  identityProfile Json?
  identityVerificationMetadata Json?
  identityProviderRawData Json?

  // Cross-schema reference to intel_persons.id in api-intelligence.
  // Null until identity resolution has produced a canonical person record.
  // Never expose this to tenant API callers — surface intelligence results
  // through the IntelligenceQueryResult shape instead.
  personId String?
  identityStatus String @default("unverified")
  identityReviewCaseId String?
  identityReviewStatus String?
  identityLastDecision String?
  identityVerificationConfidence Float?
  identityLastVerifiedAt DateTime?
  identityLivenessPassed Boolean?
  identityLivenessProvider String?
  identityLivenessConfidence Float?
  identityLivenessReason String?

  // KYC payment tracking — only populated when tenant has driverPaysKyc=true.
  kycPaymentReference  String?
  kycPaymentVerifiedAt DateTime?

  // Per-driver override for the driverPaysKyc org setting.
  // null = use the org-level default; true/false = explicit override for this driver.
  driverPaysKycOverride Boolean?

  // Admin-set override that marks this driver as eligible for assignment even when
  // the standard readiness checks are incomplete (e.g. liveness not done but all
  // other details are present). Only honoured when the org setting
  // allowAdminAssignmentOverride = true AND no active fraud flags are present.
  adminAssignmentOverride Boolean @default(false)
  adminAssignmentOverrideRequestedAt DateTime?
  adminAssignmentOverrideRequestedBy String?
  adminAssignmentOverrideReason String?
  adminAssignmentOverrideEvidence Json?
  adminAssignmentOverrideOtpHash String?
  adminAssignmentOverrideOtpExpiresAt DateTime?
  adminAssignmentOverrideConfirmedAt DateTime?
  adminAssignmentOverrideConfirmedBy String?

  // Denormalized for fast lookups without joining fleet → operating unit → business entity.
  businessEntityId String
  operatingUnitId  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fleet Fleet @relation(fields: [fleetId], references: [id], onDelete: Restrict)
  documents             DriverDocument[]
  documentVerifications DriverDocumentVerification[]
  guarantor DriverGuarantor?
  guarantorLinks GuarantorDriverLink[]
  linkedUsers User[]

  @@index([tenantId])
  @@index([fleetId])
  @@index([personId])
  // Phone unique per tenant — same driver cannot enroll twice under one tenant.
  @@unique([tenantId, phone])
  @@map("drivers")
}

model VerificationEntitlement {
  id                  String   @id
  entitlementCode     String   @unique
  subjectType         String
  subjectId           String
  tenantId            String
  payerType           String
  paymentReference    String?
  paymentProvider     String?
  amountMinorUnits    Int
  currency            String
  purpose             String
  status              String   @default("pending")
  paidAt              DateTime?
  reservedAt          DateTime?
  consumedAt          DateTime?
  expiresAt           DateTime?
  consumedByAttemptId String?
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId, subjectType, subjectId, status])
  @@index([paymentReference])
  @@map("verification_entitlements")
}

model VerificationAttempt {
  id                   String   @id
  attemptCode          String   @unique
  subjectType          String
  subjectId            String
  tenantId             String
  entitlementId        String?
  attemptType          String
  requestFingerprint   String?
  startedAt            DateTime @default(now())
  completedAt          DateTime?
  status               String   @default("initiated")
  failureReason        String?
  providerCostIncurred Boolean  @default(false)
  billableStageReached Boolean  @default(false)
  providerCallCount    Int      @default(0)
  livenessCallCount    Int      @default(0)
  metadata             Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([tenantId, subjectType, subjectId, status])
  @@index([entitlementId])
  @@index([requestFingerprint])
  @@map("verification_attempts")
}

model DriverGuarantor {
  id           String @id @default(cuid())
  tenantId     String
  driverId     String @unique
  // Cross-schema reference to intel_persons.id in api-intelligence.
  personId     String?
  name         String
  phone        String
  email        String?
  countryCode  String?
  relationship String?
  dateOfBirth  String?
  gender       String?
  selfieImageUrl   String?
  providerImageUrl String?
  status       String @default("active")
  disconnectedAt DateTime?
  disconnectedReason String?
  responsibilityAcceptedAt DateTime?
  responsibilityAcceptanceEvidence Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([driverId])
  @@index([personId])
  @@map("driver_guarantors")
}

model Guarantor {
  id           String @id @default(cuid())
  tenantId     String
  fleetId      String
  personId     String?
  name         String
  phone        String
  email        String?
  countryCode  String?
  relationship String?
  status       String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fleet Fleet @relation(fields: [fleetId], references: [id], onDelete: Restrict)
  driverLinks GuarantorDriverLink[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([fleetId])
  @@index([personId])
  @@index([status])
  @@map("guarantors")
}

model GuarantorDriverLink {
  id          String @id @default(cuid())
  tenantId    String
  guarantorId String
  driverId    String
  fleetId     String
  status      String @default("active")
  linkedAt    DateTime @default(now())
  unlinkedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guarantor Guarantor @relation(fields: [guarantorId], references: [id], onDelete: Cascade)
  driver    Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([guarantorId, driverId])
  @@index([tenantId])
  @@index([guarantorId])
  @@index([driverId])
  @@index([fleetId])
  @@index([status])
  @@map("guarantor_driver_links")
}

model DriverDocument {
  id          String @id @default(cuid())
  tenantId    String
  driverId    String
  documentType String
  fileName    String
  contentType String
  // Deprecated inline test storage. Kept nullable for migration compatibility.
  fileDataUrl String?
  // Opaque key resolved through the document storage service.
  storageKey  String?
  // Canonical object URL in backing storage. UI should still use authenticated preview routes.
  storageUrl  String?
  uploadedBy  String
  status      String @default("pending")
  expiresAt   DateTime?
  reviewedBy  String?
  reviewedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([driverId])
  @@index([status])
  @@index([expiresAt])
  @@index([storageKey])
  @@index([storageUrl])
  @@map("driver_documents")
}

// ── Driver Document Verifications ─────────────────────────────────────────────
// Zero-trust document verification using ID number + provider API.
// Replaces the file-upload-first approach for primary document verification.
// An upload (DriverDocument) remains available as a secondary/admin exception path
// controlled by fleet settings, but this is the canonical verification record.

model DriverDocumentVerification {
  id           String @id @default(cuid())
  tenantId     String
  driverId     String
  // References domain-config DOCUMENT_TYPES slug (e.g. 'national_id', 'drivers_license').
  documentType String
  // The identifier value submitted by the driver (e.g. NIN, passport number).
  idNumber     String
  // ISO 3166-1 alpha-2 country of issuance.
  countryCode  String
  // Provider used to verify: 'youverify' | 'smile_identity' | 'manual' | 'mock'.
  provider     String?
  // pending | verified | failed | manual_review | expired
  status       String  @default("pending")
  // Whether the provider returned a match against the submitted demographics.
  providerMatch Boolean?
  // Raw provider confidence score (0–100) where available.
  providerConfidence Int?
  // Demographics returned by the provider for cross-check.
  providerFirstName  String?
  providerLastName   String?
  providerDateOfBirth String?
  providerExpiryDate  String?
  // Why verification failed or was routed to manual review.
  failureReason      String?
  // Full provider response for audit, stored as JSONB.
  providerResult     Json?
  // Timestamp when provider returned a response.
  verifiedAt  DateTime?
  // Admin who completed manual review (null if automated).
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([tenantId, driverId, documentType])
  @@index([tenantId, status])
  @@map("driver_document_verifications")
}

// ── Vehicles ──────────────────────────────────────────────────────────────────
// A vehicle managed within a fleet.
//
// vehicleType: slug from domain-config VEHICLE_TYPES (e.g. 'motorcycle', 'minibus').
// plate: unique per tenant — a vehicle cannot appear in two fleets of the same tenant.

model Vehicle {
  id                String @id @default(cuid())
  tenantId          String
  fleetId           String
  systemVehicleCode String @unique
  tenantVehicleCode String
  // VehicleStatus from domain-config VEHICLE_STATUS_CODES:
  // available | assigned | maintenance | retired
  status            String @default("available")

  // Vehicle details
  // References domain-config VEHICLE_TYPES slug.
  vehicleType String
  make        String
  model       String
  trim        String?
  year        Int
  // Operator-editable asset code. Unique only within a tenant.
  // This is the primary operator-facing identifier in the UI.
  // Example: AJAH-0012
  // Plate is intentionally secondary because it may be missing or change.
  // SystemVehicleCode remains the immutable stable internal identifier.
  //
  // Normalised registration plate — optional and secondary.
  plate       String?
  color       String?
  // VIN / chassis number — optional at enrollment, required before assignment.
  vin         String?
  odometerKm  Int?

  // Denormalized for fast lookups.
  operatingUnitId  String
  businessEntityId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fleet      Fleet             @relation(fields: [fleetId], references: [id], onDelete: Restrict)
  valuations VehicleValuation[]
  inspections VehicleInspection[]
  maintenanceSchedules VehicleMaintenanceSchedule[]
  maintenanceEvents VehicleMaintenanceEvent[]
  incidents VehicleIncident[]
  inspectionRuns Inspection[]
  maintenanceScheduleRules MaintenanceScheduleRule[]
  maintenanceRecords MaintenanceRecord[]
  workOrders WorkOrder[]
  riskAssessments VehicleRiskAssessment[]

  @@index([tenantId])
  @@index([fleetId])
  @@unique([tenantId, tenantVehicleCode])
  @@unique([tenantId, plate])
  @@unique([tenantId, vin])
  @@map("vehicles")
}

model VehicleInspection {
  id                  String   @id @default(cuid())
  tenantId            String
  vehicleId           String
  createdByUserId     String?
  inspectionType      String
  status              String   @default("passed")
  inspectionDate      DateTime @default(now())
  odometerKm          Int?
  issuesFoundCount    Int      @default(0)
  reportSource        String   @default("in_app")
  summary             String
  reportUrl           String?
  nextInspectionDueAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId, vehicleId, inspectionDate])
  @@map("vehicle_inspections")
}

model VehicleMaintenanceSchedule {
  id                 String   @id @default(cuid())
  tenantId           String
  vehicleId          String
  createdByUserId    String?
  isActive           Boolean  @default(true)
  scheduleType       String
  intervalDays       Int?
  intervalKm         Int?
  nextDueAt          DateTime?
  nextDueOdometerKm  Int?
  source             String   @default("default")
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId, vehicleId, isActive])
  @@map("vehicle_maintenance_schedules")
}

model VehicleMaintenanceEvent {
  id              String   @id @default(cuid())
  tenantId        String
  vehicleId       String
  createdByUserId String?
  category        String
  title           String
  description     String?
  status          String   @default("scheduled")
  scheduledFor    DateTime?
  completedAt     DateTime?
  odometerKm      Int?
  costMinorUnits  Int?
  currency        String?
  vendor          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId, vehicleId, status])
  @@index([tenantId, vehicleId, scheduledFor])
  @@map("vehicle_maintenance_events")
}

model VehicleIncident {
  id                     String   @id @default(cuid())
  tenantId               String
  vehicleId              String
  driverId               String?
  reportedByUserId       String?
  occurredAt             DateTime
  category               String
  severity               String
  title                  String
  description            String?
  status                 String   @default("reported")
  estimatedCostMinorUnits Int?
  currency               String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId, vehicleId, occurredAt])
  @@index([tenantId, vehicleId, status])
  @@map("vehicle_incidents")
}

// Vehicle valuation events. This keeps current create/edit support small while
// preserving a clean path to richer valuation history over time.

model VehicleValuation {
  id               String @id @default(cuid())
  tenantId         String
  vehicleId        String
  valuationKind    String
  amountMinorUnits Int
  currency         String?
  valuationDate    String
  source           String?
  notes            String?
  isCurrent        Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([vehicleId])
  @@index([vehicleId, valuationKind, isCurrent])
  @@map("vehicle_valuations")
}

model OperationalAuditLog {
  id          String @id @default(cuid())
  tenantId    String
  actorId     String?
  entityType  String
  entityId    String
  action      String
  beforeState Json?
  afterState  Json?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([tenantId, entityType, entityId, createdAt])
  @@index([tenantId, actorId, createdAt])
  @@map("operational_audit_logs")
}

model PolicyRule {
  id            String @id @default(cuid())
  tenantId      String
  name          String
  conditionType String
  threshold     Int
  timeWindowDays Int
  actionType    String
  appliesTo     String
  isActive      Boolean @default(true)
  metadata      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enforcementActions EnforcementAction[]

  @@index([tenantId, isActive])
  @@index([tenantId, appliesTo, conditionType])
  @@map("policy_rules")
}

model EnforcementAction {
  id           String @id @default(cuid())
  tenantId     String
  policyRuleId String?
  entityType   String
  entityId     String
  actionType   String
  status       String @default("active")
  reason       String
  metadata     Json?
  triggeredAt  DateTime @default(now())
  resolvedAt   DateTime?
  resolvedReason String?

  policyRule PolicyRule? @relation(fields: [policyRuleId], references: [id], onDelete: SetNull)

  @@index([tenantId, entityType, entityId, status])
  @@index([tenantId, actionType, status])
  @@index([policyRuleId])
  @@map("enforcement_actions")
}

model InspectionChecklistTemplate {
  id                  String @id @default(cuid())
  tenantId            String
  name                String
  inspectionType      String
  isActive            Boolean @default(true)
  requiresReview      Boolean @default(true)
  defaultPassingScore Int @default(80)
  createdByUserId     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  items       InspectionChecklistItem[]
  inspections Inspection[]

  @@index([tenantId, inspectionType, isActive])
  @@map("inspection_checklist_templates")
}

model InspectionChecklistItem {
  id                 String @id @default(cuid())
  tenantId           String
  templateId         String
  label              String
  description        String?
  sortOrder          Int @default(0)
  weight             Int @default(1)
  isRequired         Boolean @default(true)
  requiredMediaKinds Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  template InspectionChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  results  InspectionResult[]

  @@index([tenantId, templateId, sortOrder])
  @@map("inspection_checklist_items")
}

model Inspection {
  id              String @id @default(cuid())
  tenantId        String
  vehicleId       String
  templateId      String
  driverId        String?
  assignmentId    String?
  inspectionType  String
  status          String @default("draft")
  reviewDecision  String?
  reviewComments  String?
  createdByUserId String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  odometerKm      Int?
  gpsLatitude     Float?
  gpsLongitude    Float?
  summary         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vehicle    Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  template   InspectionChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  results    InspectionResult[]
  media      InspectionMedia[]
  reviews    InspectionReview[]
  scorecards InspectionScore[]
  triggers   MaintenanceTrigger[]
  records    MaintenanceRecord[]

  @@index([tenantId, vehicleId, createdAt])
  @@index([tenantId, status, inspectionType])
  @@map("inspections")
}

model InspectionResult {
  id              String @id @default(cuid())
  tenantId        String
  inspectionId    String
  checklistItemId String
  result          String
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  inspection    Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  checklistItem InspectionChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Restrict)
  media         InspectionMedia[]

  @@index([tenantId, inspectionId])
  @@index([tenantId, checklistItemId])
  @@map("inspection_results")
}

model InspectionMedia {
  id                 String @id @default(cuid())
  tenantId           String
  inspectionId       String
  inspectionResultId String?
  mediaType          String
  viewpoint          String?
  storageKey         String?
