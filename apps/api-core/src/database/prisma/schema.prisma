// =============================================================================
// Tenant Operations Plane — Prisma Schema (api-core)
//
// Table naming: no prefix — this is the default operational plane.
// Status fields use String, not Prisma enums, so status transitions
// never require a schema migration. Valid values are enforced by the
// service layer using @mobility-os/domain-config status registries.
//
// Cross-plane references (e.g. to intel_persons in api-intelligence) are
// plain String fields. Prisma cannot model cross-schema relations; integrity
// is maintained at the application level.
//
// Generated client output: default @prisma/client runtime package
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Tenants ───────────────────────────────────────────────────────────────────
// The root of the billing and access-control hierarchy.
// One tenant = one SaaS subscription.

model Tenant {
  id      String @id @default(cuid())
  // URL-safe identifier used in subdomains and API paths.
  slug    String @unique
  name    String
  // ISO 3166-1 alpha-2 — references domain-config country registry.
  country String
  // TenantStatus values from @mobility-os/tenancy-domain.
  status  String @default("prospect")
  // Arbitrary platform metadata (e.g. CRM notes, onboarding flags).
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessEntities BusinessEntity[]
  users            User[]

  @@map("tenants")
}

// ── Business Entities ─────────────────────────────────────────────────────────
// A legal or commercial entity operated under a tenant account.
// Enterprise tenants may have many (e.g. one per city or legal entity).

model BusinessEntity {
  id       String @id @default(cuid())
  tenantId String
  name     String
  // May differ from tenant.country for multi-country enterprise operators.
  country  String
  // References domain-config BUSINESS_MODELS slug (hire-purchase, lease, etc.).
  businessModel String
  status        String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  operatingUnits OperatingUnit[]

  @@index([tenantId])
  @@map("business_entities")
}

// ── Operating Units ───────────────────────────────────────────────────────────
// A branch, depot, or operational location within a business entity.

model OperatingUnit {
  id               String @id @default(cuid())
  // Denormalized for efficient row-level filtering without joins.
  tenantId         String
  businessEntityId String
  name             String
  status           String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessEntity BusinessEntity @relation(fields: [businessEntityId], references: [id], onDelete: Restrict)
  fleets         Fleet[]

  @@index([tenantId])
  @@index([businessEntityId])
  @@map("operating_units")
}

// ── Fleets ────────────────────────────────────────────────────────────────────
// A managed group of vehicles within an operating unit.

model Fleet {
  id              String @id @default(cuid())
  tenantId        String
  operatingUnitId String
  name            String
  // References domain-config BUSINESS_MODELS slug — may differ from the
  // parent business entity's default model (e.g. mixed hire-purchase + lease fleets).
  businessModel String
  status        String @default("active")

  // Fleet-level maintenance defaults — inherited by vehicles unless overridden per vehicle.
  maintenanceScheduleType String?
  maintenanceIntervalDays Int?
  maintenanceIntervalKm   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  operatingUnit OperatingUnit @relation(fields: [operatingUnitId], references: [id], onDelete: Restrict)
  drivers       Driver[]
  guarantors    Guarantor[]
  vehicles      Vehicle[]

  @@index([tenantId])
  @@index([operatingUnitId])
  @@map("fleets")
}

// ── Vehicle Catalog ───────────────────────────────────────────────────────────
// Global local catalog of makers and models used to bootstrap operator choices.
// Runtime UI reads from this local catalog, not the external bootstrap API.
// NHTSA vPIC is used only for import/bootstrap and VIN enrichment.

model VehicleMaker {
  id             String @id @default(cuid())
  name           String
  normalizedName String @unique
  status         String @default("active")
  externalSource String?
  externalId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  models     VehicleCatalogModel[]
  vinDecodes VehicleVinDecode[]

  @@index([status])
  @@map("vehicle_makers")
}

model VehicleCatalogModel {
  id               String @id @default(cuid())
  makerId          String
  name             String
  normalizedName   String
  status           String @default("active")
  vehicleCategory  String?
  sourceTypeLabel  String?
  externalSource   String?
  externalId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  maker      VehicleMaker        @relation(fields: [makerId], references: [id], onDelete: Restrict)
  vinDecodes VehicleVinDecode[]

  @@unique([makerId, normalizedName])
  @@index([makerId])
  @@index([status])
  @@index([vehicleCategory])
  @@map("vehicle_models")
}

// VIN decode snapshots used for audit/debugging and local catalog enrichment.
// Raw decode payloads stay here instead of bloating the operational vehicles table.

model VehicleVinDecode {
  id                 String @id @default(cuid())
  vin                String
  normalizedVin      String
  decodeKey          String @unique
  requestedModelYear Int?
  status             String @default("decoded")
  source             String @default("nhtsa-vpic")
  sourceVersion      String?
  errorCode          String?
  errorText          String?
  rawPayload         Json
  decodedMake        String?
  decodedModel       String?
  decodedModelYear   Int?
  vehicleType        String?
  bodyClass          String?
  manufacturerName   String?
  makerId            String?
  modelId            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  maker VehicleMaker?        @relation(fields: [makerId], references: [id], onDelete: SetNull)
  model VehicleCatalogModel? @relation(fields: [modelId], references: [id], onDelete: SetNull)

  @@index([normalizedVin])
  @@index([makerId])
  @@index([modelId])
  @@map("vehicle_vin_decodes")
}

// ── Drivers ───────────────────────────────────────────────────────────────────
// An individual who operates a vehicle under a tenant fleet.
// Distinct from User — drivers are operational subjects, not platform users.
//
// personId: cross-schema reference to intel_persons.id in api-intelligence.
// Set after identity resolution completes. Null until then.
// See docs/intelligence/person-graph.md.

model Driver {
  id       String @id @default(cuid())
  tenantId String
  fleetId  String
  // DriverStatus from domain-config DRIVER_STATUS_CODES:
  // active | inactive | suspended | terminated
  status   String @default("inactive")

  // Personal details
  firstName   String
  lastName    String
  // E.164 format
  phone       String
  // Nullable — driver may not yet have a linked email
  email       String?
  // ISO 8601 date string (YYYY-MM-DD). Not DateTime — avoids tz ambiguity.
  dateOfBirth String?
  // ISO 3166-1 alpha-2
  nationality String?

  // Cross-schema reference to intel_persons.id in api-intelligence.
  // Null until identity resolution has produced a canonical person record.
  // Never expose this to tenant API callers — surface intelligence results
  // through the IntelligenceQueryResult shape instead.
  personId String?
  identityStatus String @default("unverified")
  identityReviewCaseId String?
  identityReviewStatus String?
  identityLastDecision String?
  identityVerificationConfidence Float?
  identityLastVerifiedAt DateTime?
  identityLivenessPassed Boolean?
  identityLivenessProvider String?
  identityLivenessConfidence Float?
  identityLivenessReason String?

  // KYC payment tracking — only populated when tenant has driverPaysKyc=true.
  kycPaymentReference  String?
  kycPaymentVerifiedAt DateTime?

  // Denormalized for fast lookups without joining fleet → operating unit → business entity.
  businessEntityId String
  operatingUnitId  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fleet Fleet @relation(fields: [fleetId], references: [id], onDelete: Restrict)
  documents DriverDocument[]
  guarantor DriverGuarantor?
  guarantorLinks GuarantorDriverLink[]
  linkedUsers User[]

  @@index([tenantId])
  @@index([fleetId])
  @@index([personId])
  // Phone unique per tenant — same driver cannot enroll twice under one tenant.
  @@unique([tenantId, phone])
  @@map("drivers")
}

model DriverGuarantor {
  id           String @id @default(cuid())
  tenantId     String
  driverId     String @unique
  // Cross-schema reference to intel_persons.id in api-intelligence.
  personId     String?
  name         String
  phone        String
  email        String?
  countryCode  String?
  relationship String?
  status       String @default("active")
  disconnectedAt DateTime?
  disconnectedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([driverId])
  @@index([personId])
  @@map("driver_guarantors")
}

model Guarantor {
  id           String @id @default(cuid())
  tenantId     String
  fleetId      String
  personId     String?
  name         String
  phone        String
  email        String?
  countryCode  String?
  relationship String?
  status       String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fleet Fleet @relation(fields: [fleetId], references: [id], onDelete: Restrict)
  driverLinks GuarantorDriverLink[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([fleetId])
  @@index([personId])
  @@index([status])
  @@map("guarantors")
}

model GuarantorDriverLink {
  id          String @id @default(cuid())
  tenantId    String
  guarantorId String
  driverId    String
  fleetId     String
  status      String @default("active")
  linkedAt    DateTime @default(now())
  unlinkedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guarantor Guarantor @relation(fields: [guarantorId], references: [id], onDelete: Cascade)
  driver    Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([guarantorId, driverId])
  @@index([tenantId])
  @@index([guarantorId])
  @@index([driverId])
  @@index([fleetId])
  @@index([status])
  @@map("guarantor_driver_links")
}

model DriverDocument {
  id          String @id @default(cuid())
  tenantId    String
  driverId    String
  documentType String
  fileName    String
  contentType String
  // Deprecated inline test storage. Kept nullable for migration compatibility.
  fileDataUrl String?
  // Opaque key resolved through the document storage service.
  storageKey  String?
  // Canonical object URL in backing storage. UI should still use authenticated preview routes.
  storageUrl  String?
  uploadedBy  String
  status      String @default("pending")
  expiresAt   DateTime?
  reviewedBy  String?
  reviewedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([driverId])
  @@index([status])
  @@index([expiresAt])
  @@index([storageKey])
  @@index([storageUrl])
  @@map("driver_documents")
}

// ── Vehicles ──────────────────────────────────────────────────────────────────
// A vehicle managed within a fleet.
//
// vehicleType: slug from domain-config VEHICLE_TYPES (e.g. 'motorcycle', 'minibus').
// plate: unique per tenant — a vehicle cannot appear in two fleets of the same tenant.

model Vehicle {
  id                String @id @default(cuid())
  tenantId          String
  fleetId           String
  systemVehicleCode String @unique
  tenantVehicleCode String
  // VehicleStatus from domain-config VEHICLE_STATUS_CODES:
  // available | assigned | maintenance | retired
  status            String @default("available")

  // Vehicle details
  // References domain-config VEHICLE_TYPES slug.
  vehicleType String
  make        String
  model       String
  trim        String?
  year        Int
  // Operator-editable asset code. Unique only within a tenant.
  // This is the primary operator-facing identifier in the UI.
  // Example: AJAH-0012
  // Plate is intentionally secondary because it may be missing or change.
  // SystemVehicleCode remains the immutable stable internal identifier.
  //
  // Normalised registration plate — optional and secondary.
  plate       String?
  color       String?
  // VIN / chassis number — optional at enrollment, required before assignment.
  vin         String?
  odometerKm  Int?

  // Denormalized for fast lookups.
  operatingUnitId  String
  businessEntityId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fleet      Fleet             @relation(fields: [fleetId], references: [id], onDelete: Restrict)
  valuations VehicleValuation[]
  inspections VehicleInspection[]
  maintenanceSchedules VehicleMaintenanceSchedule[]
  maintenanceEvents VehicleMaintenanceEvent[]
  incidents VehicleIncident[]
  inspectionRuns Inspection[]
  maintenanceScheduleRules MaintenanceScheduleRule[]
  maintenanceRecords MaintenanceRecord[]
  workOrders WorkOrder[]
  riskAssessments VehicleRiskAssessment[]

  @@index([tenantId])
  @@index([fleetId])
  @@unique([tenantId, tenantVehicleCode])
  @@unique([tenantId, plate])
  @@unique([tenantId, vin])
  @@map("vehicles")
}

model VehicleInspection {
  id                  String   @id @default(cuid())
  tenantId            String
  vehicleId           String
  createdByUserId     String?
  inspectionType      String
  status              String   @default("passed")
  inspectionDate      DateTime @default(now())
  odometerKm          Int?
  issuesFoundCount    Int      @default(0)
  reportSource        String   @default("in_app")
  summary             String
  reportUrl           String?
  nextInspectionDueAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId, vehicleId, inspectionDate])
  @@map("vehicle_inspections")
}

model VehicleMaintenanceSchedule {
  id                 String   @id @default(cuid())
  tenantId           String
  vehicleId          String
  createdByUserId    String?
  isActive           Boolean  @default(true)
  scheduleType       String
  intervalDays       Int?
  intervalKm         Int?
  nextDueAt          DateTime?
  nextDueOdometerKm  Int?
  source             String   @default("default")
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId, vehicleId, isActive])
  @@map("vehicle_maintenance_schedules")
}

model VehicleMaintenanceEvent {
  id              String   @id @default(cuid())
  tenantId        String
  vehicleId       String
  createdByUserId String?
  category        String
  title           String
  description     String?
  status          String   @default("scheduled")
  scheduledFor    DateTime?
  completedAt     DateTime?
  odometerKm      Int?
  costMinorUnits  Int?
  currency        String?
  vendor          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId, vehicleId, status])
  @@index([tenantId, vehicleId, scheduledFor])
  @@map("vehicle_maintenance_events")
}

model VehicleIncident {
  id                     String   @id @default(cuid())
  tenantId               String
  vehicleId              String
  driverId               String?
  reportedByUserId       String?
  occurredAt             DateTime
  category               String
  severity               String
  title                  String
  description            String?
  status                 String   @default("reported")
  estimatedCostMinorUnits Int?
  currency               String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId, vehicleId, occurredAt])
  @@index([tenantId, vehicleId, status])
  @@map("vehicle_incidents")
}

// Vehicle valuation events. This keeps current create/edit support small while
// preserving a clean path to richer valuation history over time.

model VehicleValuation {
  id               String @id @default(cuid())
  tenantId         String
  vehicleId        String
  valuationKind    String
  amountMinorUnits Int
  currency         String?
  valuationDate    String
  source           String?
  notes            String?
  isCurrent        Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([vehicleId])
  @@index([vehicleId, valuationKind, isCurrent])
  @@map("vehicle_valuations")
}

model OperationalAuditLog {
  id          String @id @default(cuid())
  tenantId    String
  actorId     String?
  entityType  String
  entityId    String
  action      String
  beforeState Json?
  afterState  Json?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([tenantId, entityType, entityId, createdAt])
  @@index([tenantId, actorId, createdAt])
  @@map("operational_audit_logs")
}

model InspectionChecklistTemplate {
  id                  String @id @default(cuid())
  tenantId            String
  name                String
  inspectionType      String
  isActive            Boolean @default(true)
  requiresReview      Boolean @default(true)
  defaultPassingScore Int @default(80)
  createdByUserId     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  items       InspectionChecklistItem[]
  inspections Inspection[]

  @@index([tenantId, inspectionType, isActive])
  @@map("inspection_checklist_templates")
}

model InspectionChecklistItem {
  id                 String @id @default(cuid())
  tenantId           String
  templateId         String
  label              String
  description        String?
  sortOrder          Int @default(0)
  weight             Int @default(1)
  isRequired         Boolean @default(true)
  requiredMediaKinds Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  template InspectionChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  results  InspectionResult[]

  @@index([tenantId, templateId, sortOrder])
  @@map("inspection_checklist_items")
}

model Inspection {
  id              String @id @default(cuid())
  tenantId        String
  vehicleId       String
  templateId      String
  driverId        String?
  assignmentId    String?
  inspectionType  String
  status          String @default("draft")
  reviewDecision  String?
  reviewComments  String?
  createdByUserId String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  odometerKm      Int?
  gpsLatitude     Float?
  gpsLongitude    Float?
  summary         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vehicle    Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  template   InspectionChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  results    InspectionResult[]
  media      InspectionMedia[]
  reviews    InspectionReview[]
  scorecards InspectionScore[]
  triggers   MaintenanceTrigger[]
  records    MaintenanceRecord[]

  @@index([tenantId, vehicleId, createdAt])
  @@index([tenantId, status, inspectionType])
  @@map("inspections")
}

model InspectionResult {
  id              String @id @default(cuid())
  tenantId        String
  inspectionId    String
  checklistItemId String
  result          String
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  inspection    Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  checklistItem InspectionChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Restrict)
  media         InspectionMedia[]

  @@index([tenantId, inspectionId])
  @@index([tenantId, checklistItemId])
  @@map("inspection_results")
}

model InspectionMedia {
  id                 String @id @default(cuid())
  tenantId           String
  inspectionId       String
  inspectionResultId String?
  mediaType          String
  viewpoint          String?
  storageKey         String?
  storageUrl         String?
  capturedAt         DateTime @default(now())
  aiAnalysis         Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  inspection       Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  inspectionResult InspectionResult? @relation(fields: [inspectionResultId], references: [id], onDelete: SetNull)

  @@index([tenantId, inspectionId])
  @@index([tenantId, inspectionResultId])
  @@map("inspection_media")
}

model InspectionReview {
  id             String @id @default(cuid())
  tenantId       String
  inspectionId   String
  reviewerUserId String
  decision       String
  comments       String?
  createdAt      DateTime @default(now())

  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([tenantId, inspectionId, createdAt])
  @@map("inspection_reviews")
}

model InspectionScore {
  id               String @id @default(cuid())
  tenantId         String
  inspectionId     String
  score            Int
  riskLevel        String
  failedItemCount  Int @default(0)
  warningItemCount Int @default(0)
  calculatedAt     DateTime @default(now())

  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([tenantId, inspectionId, calculatedAt])
  @@map("inspection_scores")
}

model MaintenanceVendor {
  id          String @id @default(cuid())
  tenantId    String
  name        String
  contactName String?
  phone       String?
  email       String?
  status      String @default("approved")
  rating      Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workOrders WorkOrder[]

  @@index([tenantId, status])
  @@map("maintenance_vendors")
}

model MaintenanceScheduleRule {
  id                String @id @default(cuid())
  tenantId          String
  vehicleId         String
  name              String
  scheduleType      String
  intervalDays      Int?
  intervalKm        Int?
  nextDueAt         DateTime?
  nextDueOdometerKm Int?
  isActive          Boolean @default(true)
  source            String @default("default")
  createdByUserId   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId, vehicleId, isActive])
  @@map("maintenance_schedule_rules")
}

model MaintenanceTrigger {
  id          String @id @default(cuid())
  tenantId    String
  vehicleId   String
  inspectionId String?
  triggerType String
  severity    String
  summary     String
  metadata    Json?
  createdAt   DateTime @default(now())

  inspection Inspection? @relation(fields: [inspectionId], references: [id], onDelete: SetNull)
  records    MaintenanceRecord[]

  @@index([tenantId, vehicleId, createdAt])
  @@map("maintenance_triggers")
}

model MaintenanceRecord {
  id              String @id @default(cuid())
  tenantId        String
  vehicleId       String
  inspectionId    String?
  triggerId       String?
  recordType      String
  status          String @default("open")
  openedAt        DateTime @default(now())
  closedAt        DateTime?
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vehicle    Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  inspection Inspection? @relation(fields: [inspectionId], references: [id], onDelete: SetNull)
  trigger    MaintenanceTrigger? @relation(fields: [triggerId], references: [id], onDelete: SetNull)
  workOrders WorkOrder[]

  @@index([tenantId, vehicleId, status])
  @@map("maintenance_records")
}

model WorkOrder {
  id                  String @id @default(cuid())
  tenantId            String
  vehicleId           String
  maintenanceRecordId String
  vendorId            String?
  issueDescription    String
  priority            String
  status              String @default("pending")
  assignedAt          DateTime?
  startedAt           DateTime?
  completedAt         DateTime?
  rejectedAt          DateTime?
  createdByUserId     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  vehicle           Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  maintenanceRecord MaintenanceRecord @relation(fields: [maintenanceRecordId], references: [id], onDelete: Cascade)
  vendor            MaintenanceVendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  costs             MaintenanceCost[]

  @@index([tenantId, vehicleId, status])
  @@index([tenantId, vendorId, createdAt])
  @@map("work_orders")
}

model MaintenanceCost {
  id                    String @id @default(cuid())
  tenantId              String
  workOrderId           String
  partsCostMinorUnits   Int @default(0)
  labourCostMinorUnits  Int @default(0)
  totalCostMinorUnits   Int
  currency              String
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([tenantId, workOrderId])
  @@map("maintenance_costs")
}

model VehicleRiskAssessment {
  id                 String @id @default(cuid())
  tenantId           String
  vehicleId          String
  score              Int
  riskLevel          String
  reasons            Json
  isAssignmentLocked Boolean @default(false)
  evaluatedAt        DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId, vehicleId, evaluatedAt])
  @@map("vehicle_risk_assessments")
}

// ── Assignments ───────────────────────────────────────────────────────────────
// A driver–vehicle pairing within a fleet for an operational period.
// Only one active assignment per driver and per vehicle at any time (enforced
// at the service layer; no DB unique because completed assignments are retained).
//
// AssignmentStatus from domain-config ASSIGNMENT_STATUS_CODES:
//   created | assigned | active | completed (terminal) | cancelled (terminal)

model Assignment {
  id        String @id @default(cuid())
  tenantId  String
  fleetId   String
  driverId  String
  vehicleId String
  // AssignmentStatus from domain-config ASSIGNMENT_STATUS_CODES.
  status    String @default("assigned")

  startedAt DateTime @default(now())
  // Null while the assignment is active.
  endedAt   DateTime?
  // Free-text reason for suspension or cancellation.
  notes     String?

  // Planned remittance terms for this assignment. These are nullable so existing
  // assignments created before remittance planning remain valid.
  remittanceModel            String?
  remittanceFrequency        String?
  remittanceAmountMinorUnits Int?
  remittanceCurrency         String?
  // ISO 8601 date (YYYY-MM-DD) representing the first scheduled due date.
  remittanceStartDate        String?
  // Monday = 1 ... Sunday = 7. Used when frequency is weekly.
  remittanceCollectionDay    Int?

  // Denormalized for filtering without joins.
  operatingUnitId  String
  businessEntityId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([driverId])
  @@index([vehicleId])
  @@index([fleetId, status])
  @@map("assignments")
}

// ── Remittance ────────────────────────────────────────────────────────────────
// A periodic payment from a driver to the operator.
// Immutable after confirmation — disputes create a new row, not an update.
//
// RemittanceStatus from domain-config REMITTANCE_STATUS_CODES:
//   pending | confirmed (terminal) | disputed (terminal) | waived (terminal)
//
// amount is stored in minor currency units (e.g. kobo).
// currency is ISO 4217 — must match the tenant's operational wallet currency.

model Remittance {
  id           String @id @default(cuid())
  tenantId     String
  assignmentId String
  driverId     String
  vehicleId    String
  // RemittanceStatus from domain-config REMITTANCE_STATUS_CODES.
  status       String @default("pending")

  // Amount in minor currency units (always positive).
  amountMinorUnits Int
  // ISO 4217. Must match the tenant operational wallet currency.
  currency         String
  // Expected payment date (ISO 8601 date, not DateTime — avoids tz ambiguity).
  dueDate          String
  // Actual payment date. Null until confirmed.
  paidDate         String?
  notes            String?

  // Denormalized for fast lookups.
  fleetId          String
  operatingUnitId  String
  businessEntityId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([assignmentId])
  @@index([driverId])
  @@index([tenantId, status])
  @@map("remittances")
}

// ── Operational Wallets ───────────────────────────────────────────────────────
// Tenant-side cash / float wallet. Distinct from cp_platform_wallets (SaaS billing).
// See docs/decisions/ADR-009-wallet-separation.md.
//
// One operational wallet per business entity. Balance is derived from ledger entries.
// Table prefix ow_* (operational wallet) to distinguish from cp_* (control-plane).

model OperationalWallet {
  id               String @id @default(cuid())
  tenantId         String
  businessEntityId String @unique
  // ISO 4217. Must match the tenant's plan currency.
  currency         String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries OperationalWalletEntry[]

  @@index([tenantId])
  @@map("ow_wallets")
}

// Operational wallet ledger (double-entry, append-only).
// Balance = SUM(amount WHERE type = 'credit') - SUM(amount WHERE type = 'debit')
// Corrections are new reversal rows — existing rows are never mutated.

model OperationalWalletEntry {
  id       String @id @default(cuid())
  walletId String
  // WalletEntryType: credit | debit | reversal
  type     String
  // Amount in minor currency units. Always positive — type encodes direction.
  amountMinorUnits Int
  currency         String
  // ID of the originating event (remittance, adjustment, etc.).
  referenceId   String?
  // 'remittance' | 'adjustment' | 'reversal' | 'payout'
  referenceType String?
  description   String?

  createdAt DateTime @default(now())
  // No updatedAt — entries are immutable after creation.

  wallet OperationalWallet @relation(fields: [walletId], references: [id], onDelete: Restrict)

  @@index([walletId])
  @@map("ow_wallet_entries")
}

// ── Users ─────────────────────────────────────────────────────────────────────
// Tenant platform users (operators, managers, field staff).
// Not to be confused with drivers — drivers are a separate operational entity.

model User {
  id       String @id @default(cuid())
  tenantId String
  driverId String?
  email    String
  phone    String?
  name     String
  // TenantRole from @mobility-os/authz-model.
  role     String
  isActive Boolean @default(true)
  isEmailVerified Boolean @default(false)
  mobileAccessRevoked Boolean @default(false)

  // Access scope — absent means tenant-wide access (e.g. TENANT_OWNER).
  // Present when the user is scoped to a specific business entity or unit.
  businessEntityId String?
  operatingUnitId  String?

  // Hashed password for local auth. Null if using SSO only.
  passwordHash String?
  settings     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driver Driver? @relation(fields: [driverId], references: [id], onDelete: SetNull)
  authOtps AuthOtp[]
  passwordResetTokens PasswordResetToken[]
  refreshTokens AuthRefreshToken[]
  notifications UserNotification[]
  pushDevices UserPushDevice[]

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
  @@unique([tenantId, driverId])
  @@index([tenantId])
  @@index([driverId])
  @@map("users")
}

model UserNotification {
  id        String @id @default(cuid())
  tenantId  String
  userId    String
  topic     String
  title     String
  body      String
  actionUrl String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, createdAt])
  @@index([tenantId, userId, readAt])
  @@index([topic])
  @@map("user_notifications")
}

model UserPushDevice {
  id            String @id @default(cuid())
  tenantId      String
  userId        String
  deviceToken   String
  platform      String
  disabledAt    DateTime?
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceToken])
  @@index([tenantId, userId])
  @@index([deviceToken])
  @@map("user_push_devices")
}

model AuthRefreshToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_refresh_tokens")
}

model AuthOtp {
  id         String   @id @default(cuid())
  userId     String
  identifier String
  purpose    String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@index([identifier, purpose])
  @@index([expiresAt])
  @@map("auth_otps")
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ── Self-Service OTPs ─────────────────────────────────────────────────────────
// Short-lived one-time passcodes that allow drivers and guarantors to start their
// self-service verification flow from the mobile app without clicking a link.
// OTP is generated alongside the JWT self-service token and included in the email.

model SelfServiceOtp {
  id          String    @id @default(cuid())
  tenantId    String
  // "driver" or "guarantor" — indicates which subject this OTP belongs to
  subjectType String
  // For drivers: driverId. For guarantors: driverId (the linked driver).
  subjectId   String
  otpCode     String    @unique
  expiresAt   DateTime
  usedAt      DateTime?

  createdAt DateTime @default(now())

  @@index([otpCode])
  @@index([tenantId, subjectId])
  @@map("self_service_otps")
}
