{
  "expo": {
    "name": "Mobiris Fleet OS",
    "slug": "mobiris-mobile-ops",
    "scheme": [
      "mobiris-mobile-ops",
      "mobiris"
    ],
    "version": "1.1.0",
    "icon": "../../docs/ux/mobiris-brand/icons/png/icon-1024.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "autolinking": {
      "nativeModulesDir": "./modules"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Mobiris to access photos for driver verification documents.",
          "cameraPermission": "Allow Mobiris to use the camera for live selfie and liveness verification during onboarding."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mobiris.mobileops",
      "associatedDomains": [
        "applinks:app.mobiris.ng"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "../../docs/ux/mobiris-brand/icons/png-transparent/icon-transparent-512.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.mobiris.mobileops",
      "versionCode": 4,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "app.mobiris.ng",
              "pathPrefix": "/driver-self-service"
            },
            {
              "scheme": "https",
              "host": "app.mobiris.ng",
              "pathPrefix": "/guarantor-self-service"
            },
            {
              "scheme": "https",
              "host": "app.mobiris.ng",
              "pathPrefix": "/reset-password"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "extra": {
      "apiUrl": "https://api.mobiris.ng/api/v1",
      "tenantWebUrl": "https://app.mobiris.ng",
      "enableOfflineQueue": true,
      "enableCrashReporting": false,
      "eas": {
        "projectId": "83ea2b51-d020-415e-a1f7-ceac04c41d87"
      }
    }
  }
}
