{
  "expo": {
    "name": "Mobiris Mobile Ops",
    "slug": "mobiris-mobile-ops",
    "scheme": [
      "mobiris-mobile-ops",
      "mobiris"
    ],
    "version": "1.0.0",
    "icon": "../../docs/ux/mobiris-brand/icons/png/icon-1024.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Mobiris to access photos for driver verification documents.",
          "cameraPermission": "Allow Mobiris to use the camera for driver selfie verification."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mobiris.mobileops"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "../../docs/ux/mobiris-brand/icons/png-transparent/icon-transparent-512.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.mobiris.mobileops",
      "versionCode": 3
    },
    "extra": {
      "apiUrl": "https://api.mobiris.ng/api/v1",
      "enableOfflineQueue": true,
      "enableCrashReporting": false
    }
  }
}
